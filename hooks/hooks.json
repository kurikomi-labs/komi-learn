{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m komi.adapters.claude_code.hook_recall"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m komi.adapters.claude_code.hook_distill"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m komi.adapters.claude_code.hook_distill"
          }
        ]
      }
    ]
  }
}
